{
  "name": "@particle-academy/fancy-query",
  "version": "0.1.1",
  "description": "Server-state for React + Inertia + Reverb apps — a thin wrapper over TanStack Query that adds Inertia page-prop hydration, declarative Echo-event → query invalidation, and auto-invalidating mutations. The value-add is the integrations, not the cache.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Particle-Academy/fancy-query.git"
  },
  "homepage": "https://github.com/Particle-Academy/fancy-query#readme",
  "bugs": "https://github.com/Particle-Academy/fancy-query/issues",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "tsup"
  },
  "keywords": [
    "react",
    "tanstack-query",
    "react-query",
    "inertia",
    "laravel-echo",
    "reverb",
    "server-state",
    "data-fetching"
  ],
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "@inertiajs/react": "^1.0.0 || ^2.0.0 || ^3.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "@inertiajs/react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@inertiajs/react": "^3.0.0",
    "@tanstack/react-query": "^5.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}
